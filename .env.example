# New Relic configuration for the Docker `app` service.
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# your values. `.env` is git-ignored so your license key stays out of source control.
#
#   cp .env.example .env
#
# Then rebuild + restart:  docker compose build app && docker compose up -d app

# REQUIRED — your New Relic "INGEST - LICENSE" key (40 chars).
# Get it from: New Relic UI -> user menu -> API keys -> type "INGEST - LICENSE".
NEW_RELIC_LICENSE_KEY=

# App name shown in New Relic APM. Keep it in sync with the Magento module's
# app_name config so APM and custom events line up.
NEW_RELIC_APPNAME=Magento 2.4.9 (Local Docker)

# Master on/off switch and distributed tracing.
NEW_RELIC_ENABLED=true
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# EU data center ONLY — if you chose EU at signup, set this. Leave blank for US.
# NEW_RELIC_HOST=collector.eu.nr-data.net
NEW_RELIC_HOST=
